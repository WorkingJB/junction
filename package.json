{
  "name": "junction",
  "version": "0.1.0",
  "private": true,
  "description": "A unified platform for managing human tasks and AI agent work",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --recursive lint",
    "type-check": "pnpm --recursive type-check",
    "clean": "pnpm --recursive clean && rm -rf node_modules",
    "mcp-server": "pnpm --filter mcp-server dev"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.18.3",
  "keywords": [
    "task-management",
    "ai-agents",
    "productivity",
    "mcp",
    "agent-tracking"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/junction"
  }
}
